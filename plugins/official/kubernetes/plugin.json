{
  "id": "official.kubernetes",
  "name": "Kubernetes",
  "version": "0.2.0",
  "manifestVersion": "1",
  "dockscopeApiVersion": "1",
  "hostApiVersion": "1",
  "description": "Adds Kubernetes graph, logs, restart, delete, and HPA scale actions through kubectl.",
  "entry": "./plugin.mjs",
  "capabilities": ["source.graph", "source.logs", "action.lifecycle", "action.scale"],
  "permissions": ["kubernetes.api", "process.exec"],
  "execution": {
    "isolation": "process",
    "operationTimeoutMs": 30000,
    "maxStderrBytes": 64000,
    "memoryLimitMb": 128
  },
  "compatibility": {
    "minDockscopeVersion": "0.7.1"
  }
}
