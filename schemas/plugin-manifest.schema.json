{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ManuelR-T/dockscope/main/schemas/plugin-manifest.schema.json",
  "title": "DockScope Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "manifestVersion",
    "dockscopeApiVersion",
    "hostApiVersion",
    "entry",
    "capabilities",
    "permissions"
  ],
  "properties": {
    "$schema": { "type": "string", "format": "uri-reference" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "manifestVersion": { "const": "1" },
    "dockscopeApiVersion": { "const": "1" },
    "hostApiVersion": { "const": "1" },
    "description": { "type": "string", "minLength": 1 },
    "entry": { "type": "string", "minLength": 1 },
    "builtin": { "type": "boolean" },
    "author": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string", "format": "uri" },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "source.graph",
          "source.metrics",
          "source.events",
          "source.logs",
          "source.inspect",
          "source.inventory",
          "source.relationships",
          "source.system",
          "source.connections",
          "action.lifecycle",
          "action.exec",
          "action.filesystem",
          "action.deploy",
          "action.scale",
          "action.remediate",
          "analysis.diagnostics",
          "analysis.anomalies",
          "analysis.health",
          "analysis.policy",
          "analysis.cost",
          "analysis.recommendations",
          "ui.nodePanel",
          "ui.nodeAction",
          "ui.sidebarPanel",
          "ui.navigation",
          "ui.graphOverlay",
          "ui.toolbarAction",
          "ui.settings",
          "ui.command",
          "ui.frontend",
          "integration.export",
          "integration.import",
          "integration.webhook",
          "integration.search",
          "integration.alerts"
        ]
      }
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "docker.socket",
          "kubernetes.api",
          "network.local",
          "network.http",
          "filesystem.read",
          "filesystem.write",
          "process.exec",
          "secrets.read"
        ]
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isolation": { "enum": ["process", "in-process"] },
        "operationTimeoutMs": { "type": "number", "minimum": 100, "maximum": 300000 },
        "commandTimeoutMs": {
          "type": "number",
          "minimum": 100,
          "maximum": 300000,
          "deprecated": true
        },
        "maxStderrBytes": { "type": "number", "minimum": 1024, "maximum": 1000000 },
        "memoryLimitMb": { "type": "number", "minimum": 32, "maximum": 2048 }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "ui": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slot", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "slot": {
            "enum": [
              "toolbar",
              "navigation",
              "sidebar",
              "nodePanel",
              "nodeAction",
              "graphOverlay",
              "settings"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "icon": { "type": "string" },
          "order": { "type": "number" },
          "height": { "type": "number", "minimum": 48, "maximum": 640 },
          "frontendView": { "type": "string", "minLength": 1 },
          "context": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "runtimes": { "type": "array", "items": { "type": "string" } },
              "kinds": { "type": "array", "items": { "type": "string" } },
              "statuses": { "type": "array", "items": { "type": "string" } }
            }
          },
          "content": { "type": "object" },
          "action": { "type": "object" }
        }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry", "slots"],
      "properties": {
        "entry": { "type": "string", "minLength": 1 },
        "slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "toolbar",
              "navigation",
              "sidebar",
              "nodePanel",
              "nodeAction",
              "graphOverlay",
              "settings"
            ]
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minDockscopeVersion": { "type": "string" },
        "maxDockscopeVersion": { "type": "string" },
        "deprecations": { "type": "array", "items": { "type": "string" } },
        "migrations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "notes": { "type": "string" },
              "commandId": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "type"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "type": { "enum": ["string", "number", "boolean", "select"] },
        "required": { "type": "boolean" },
        "default": { "type": ["string", "number", "boolean"] },
        "placeholder": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": ["string", "number", "boolean"] }
            }
          }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "confirm": { "type": "boolean" },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fields"],
          "properties": {
            "fields": { "type": "array", "items": { "$ref": "#/$defs/field" } }
          }
        }
      }
    }
  }
}
