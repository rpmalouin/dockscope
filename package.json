{
  "name": "dockscope",
  "version": "0.8.0",
  "description": "Visual, interactive Docker infrastructure debugger — 3D dependency graph with live health, logs, and metrics",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin-sdk.d.ts",
      "import": "./dist/plugin-sdk.js"
    },
    "./plugin-sdk": {
      "types": "./dist/plugin-sdk.d.ts",
      "import": "./dist/plugin-sdk.js"
    },
    "./plugin-sdk/v1": {
      "types": "./dist/plugin-sdk-v1.d.ts",
      "import": "./dist/plugin-sdk-v1.js"
    },
    "./plugin-manifest.schema.json": {
      "default": "./schemas/plugin-manifest.schema.json"
    }
  },
  "bin": {
    "dockscope": "dist/cli.js"
  },
  "scripts": {
    "dev": "DOCKSCOPE_DEV=1 tsx watch --exclude \"$HOME/.dockscope/plugins/**\" --exclude \"../../../.dockscope/plugins/**\" --exclude \"/tmp/dockscope-*/**\" --exclude \"../../../../../tmp/dockscope-*/**\" src/cli.ts up --no-port-check",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/cli.js up",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "typecheck:plugin-compat": "tsc -p tsconfig.plugin-compat.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,svelte,css}' 'compat/**/*.ts' 'scripts/**/*.mjs' 'plugins/**/*.{mjs,json,md}' 'schemas/*.json' '.github/workflows/*.yml'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte,css}' 'compat/**/*.ts' 'scripts/**/*.mjs' 'plugins/**/*.{mjs,json,md}' 'schemas/*.json' '.github/workflows/*.yml'",
    "plugins:catalog": "node scripts/build-plugin-catalog.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "docker",
    "devops",
    "visualization",
    "3d",
    "debugging",
    "infrastructure",
    "compose"
  ],
  "author": "Manuel Tomé",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.4",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.31",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "3d-force-graph": "^1.79.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.6.0",
    "three": "^0.170.0",
    "three-spritetext": "^1.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist/",
    "schemas/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ManuelR-T/dockscope.git"
  },
  "engines": {
    "node": ">=20"
  }
}
